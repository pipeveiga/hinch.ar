{
  "expo": {
    "name": "Hinch.ar",
    "slug": "hinchar",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "hinchar",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ar.hinch.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Necesitamos acceso a tu cámara para verificar tu identidad y subir fotos de tu auto.",
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tus fotos para tu foto de perfil y del auto.",
        "NSLocationWhenInUseUsageDescription": "Usamos tu ubicación para mostrarte viajes cercanos a vos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "googleServicesFile": "./google-services.json",
      "package": "ar.hinch.app",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png",
      "name": "Hinch.ar",
      "shortName": "Hinch.ar",
      "description": "Compartí el viaje, viví el partido."
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Usamos tu ubicación para mostrarte eventos cerca tuyo."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1D4ED8",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "ae2580a6-de87-4310-a1dc-fcf283649676"
      }
    }
  }
}
