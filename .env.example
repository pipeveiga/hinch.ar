# Supabase — copiá estos valores desde tu proyecto en supabase.com
EXPO_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXXXXXXXX

# (Opcional) Google Maps API Key para autocompletado de direcciones
EXPO_PUBLIC_GOOGLE_MAPS_KEY=

# ─────────────────────────────────────────────────────────────────────────
# iOS — solo necesario para `eas submit -p ios` (no para correr la app)
# Estos valores se obtienen en App Store Connect / Apple Developer.
# No commitear el .env real (está en .gitignore).
# Alternativa más segura para CI: usar `eas secret:create` en lugar de .env.
# ─────────────────────────────────────────────────────────────────────────

# App Store Connect "Apple ID" de la app (numérico, ~10 dígitos).
# App Store Connect → My Apps → tu app → App Information → "Apple ID".
ASC_APP_ID=

# Apple Developer Team ID (10 caracteres alfanuméricos).
# developer.apple.com → Account → Membership Details → Team ID.
APPLE_TEAM_ID=

# App Store Connect API Key — generala en:
# App Store Connect → Users and Access → Integrations → Keys → "+"
# Descargás un archivo .p8 (UNA sola vez) — guardalo en credentials/AuthKey.p8
# La carpeta credentials/ ya está gitignoreada vía *.p8.
ASC_API_KEY_ID=
ASC_API_KEY_ISSUER_ID=
